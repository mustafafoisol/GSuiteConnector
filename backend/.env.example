# Copy to .env and fill in.

# --- Claude (AI command bar) ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Google OAuth ---
# Path (relative to backend/) to the OAuth client file you downloaded from
# Google Cloud Console (OAuth client of type "Web application").
GOOGLE_CLIENT_SECRET_FILE=client_secret.json
# Where the refresh token is cached after first consent.
TOKEN_FILE=token.json
# Must EXACTLY match an "Authorized redirect URI" on the OAuth client.
OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/callback

# --- App ---
FRONTEND_ORIGIN=http://localhost:5173
